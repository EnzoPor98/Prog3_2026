    class Calzado {
        -_sku: int 
        +nombre : str 
        +descripcion : str 
        +tipo : CalzadoTipo 
        +talle : CalzadoTalle
        +color: CalzadoColor
        -_cantidad : int 
        -_precio : float

        +total() : float
    }       

    class CalzadoTipo {
        +descripcion: str
    }

    class CalzadoTalle {
        +descripcion: str
        +medida_en_cm : float
    }
    
    class CalzadoColor {
        +primario: str
        +secundario: Optional[str]
    }

    class CalzadoAdminAbstract {
