        -_lista : List[Calzado]
        +*agregar_calzado(calzado: Calzado) : None
        +*eliminar_calzado(sku: int) : None
        +*modificar_calzado(calzado: Calzado) : None
        +*buscar_calzado(sku: int) : Optional[Calzado]
    }

    class CalzadoAdmin {
        +agregar_calzado(calzado: Calzado) : None
        +eliminar_calzado(sku: int) : None
        +modificar_calzado(calzado: Calzado) : None
        +buscar_calzado(sku: int) : Optional[Calzado]
    }

